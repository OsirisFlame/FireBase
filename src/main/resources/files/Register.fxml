<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.csc325_firebase_webview_auth.view.RegisterController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color: #2c3e50; -fx-padding: 40;"
      prefWidth="400" prefHeight="500">

    <Label text="Create Account"
           style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TextField fx:id="emailField" promptText="Email"
               prefWidth="300"/>

    <PasswordField fx:id="passwordField" promptText="Password"
                   prefWidth="300"/>

    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                   prefWidth="300"/>

    <Button text="Register"
            prefWidth="300" onAction="#handleRegister"/>

    <Label fx:id="messageLabel"
           style="-fx-text-fill: red; -fx-font-size: 12px;"/>

    <Label text="Already have an account?"
           style="-fx-text-fill: #aaaaaa;"/>

    <Button text="Sign in here"
            onAction="#goToLogin"
            style="-fx-background-color: transparent; -fx-text-fill: #3498db;"/>

</VBox>