<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.csc325_firebase_webview_auth.view.SplashController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #2c3e50;"
      prefWidth="600" prefHeight="400">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <Label text="Welcome to FirebaseApp"
           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>

    <Label text="Loading..."
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>

    <ProgressBar fx:id="progressBar" prefWidth="300"/>

</VBox>